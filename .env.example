APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Atlas storage root (defaults to storage/app/atlas)
# Use forward slashes or single quotes to avoid escape parsing.
#ATLAS_STORAGE=D:/Atlas
#ATLAS_STORAGE="D:\\Atlas"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

SCOUT_DRIVER=typesense
# Optional explicit prefix when sharing one Typesense instance across environments.
# SCOUT_PREFIX=atlas_local_
TYPESENSE_API_KEY=xyz
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

REVERB_APP_ID=1001
REVERB_APP_KEY=laravel-herd
REVERB_APP_SECRET=secret
REVERB_HOST=reverb-8080.herd.test
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

DOWNLOADS_MAX_TRANSFERS_TOTAL=20
DOWNLOADS_MAX_TRANSFERS_PER_DOMAIN=20
# Optional local unpacked extension target.
# Canonical extension archives are written to public/downloads unless --output-dir is passed.
# EXTENSION_LOCAL_EXTRACT_DIR=/absolute/path/to/local/extension/folder
# Legacy alias:
# EXTENSION_LOCAL_PACKAGE_DIR=/absolute/path/to/local/extension/folder
DOWNLOADS_FFMPEG_PATH=ffmpeg
DOWNLOADS_FFMPEG_TIMEOUT_SECONDS=120
DOWNLOADS_VIDEO_PREVIEW_WIDTH=450
DOWNLOADS_VIDEO_POSTER_SECOND=1
# Optional yt-dlp cookies for authenticated/age-restricted media
# DOWNLOADS_YT_DLP_COOKIES_PATH=/absolute/path/to/yt-dlp-cookies.txt
# DOWNLOADS_YT_DLP_COOKIES_FROM_BROWSER=firefox
# Optional JS runtime selection for yt-dlp challenge solving (YouTube, etc.).
# DOWNLOADS_YT_DLP_JS_RUNTIMES=node
# Optional parallel fragment fetching for segmented yt-dlp downloads (HLS/DASH).
# DOWNLOADS_YT_DLP_CONCURRENT_FRAGMENTS=4

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost/auth/spotify/callback
# Space or comma separated scopes.
SPOTIFY_SCOPES="user-read-email user-read-private playlist-read-private playlist-read-collaborative streaming user-read-playback-state user-modify-playback-state user-read-currently-playing"

VITE_APP_NAME="${APP_NAME}"
